# ----------------------------------------------------------------------------
# LuxeSupply × Jomashop integration — environment variables
# ----------------------------------------------------------------------------
# Copy to .env and fill in. NEVER commit .env. NEVER paste secrets in chat.
# After deploy, set the same values in your hosting platform's secret manager.
# ----------------------------------------------------------------------------

# App
NODE_ENV=development
PORT=5000
# Public URL of this app. MUST be HTTPS in production. Used to derive the
# Shopify redirect URL and to render copy-paste setup helpers.
APP_URL=https://your-deployed-app.example.com
# Random 32+ char string used for any future signed-cookie or HMAC helpers.
SESSION_SECRET=replace-me-with-32-random-bytes
# Random 32+ char string required to unlock /api/* routes in production.
# Send requests with: Authorization: Bearer <ADMIN_TOKEN>
ADMIN_TOKEN=

# Shopify Dev Dashboard app (LuxeSupply / luxesupply.com)
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Optional fallback for development / private-app workflows when the full
# OAuth install has not been run. If both are set and no OAuth-installed
# store is present, the Products preview will use these to call the
# Shopify Admin API directly.
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_SHOP_DOMAIN=
# Same value as APP_URL above — Shopify validates exact match against the
# App URL field in the Dev Dashboard.
SHOPIFY_APP_URL=https://your-deployed-app.example.com
# Comma-separated list. Defaults to read/write across products, inventory,
# orders, locations, and fulfillment.
SHOPIFY_SCOPES=read_products,write_products,read_inventory,write_inventory,read_orders,write_orders,read_locations,read_fulfillments,write_fulfillments,read_assigned_fulfillment_orders,write_assigned_fulfillment_orders

# Jomashop Vendor API
JOMASHOP_API_BASE_URL=https://api.vendor.jomashop.com
JOMASHOP_EMAIL=
JOMASHOP_PASSWORD=

# ----------------------------------------------------------------------------
# Automation / auto-sync (Farfetch-style). SAFE DEFAULTS: everything off.
# ----------------------------------------------------------------------------
# Master switch for the scheduled jobs. false = no timers start at all.
AUTO_SYNC_ENABLED=false
# When true (default), scheduled + manual runs only PLAN and log - no
# Jomashop writes. A live run requires AUTO_SYNC_ENABLED=true AND
# AUTO_SYNC_DRY_RUN=false (and, for manual runs, dryRun:false in the body).
AUTO_SYNC_DRY_RUN=true
# Minutes between scheduled inventory syncs (Shopify -> Jomashop). Min 5.
INVENTORY_SYNC_INTERVAL_MINUTES=30
# Minutes between scheduled Jomashop order pulls (always preview-only). Min 5.
ORDER_PULL_INTERVAL_MINUTES=15
# Per-SKU safety cap: skip + flag any inventory change larger than this.
MAX_INVENTORY_DELTA=25
# Surfaced in the Automation status only. Shopify order CREATION is never
# automatic - it stays behind POST /api/jomashop/orders/import-to-shopify
# with an explicit confirm:true body.
ORDER_IMPORT_ENABLED=false

# ----------------------------------------------------------------------------
# Embedded Shopify admin app (App Bridge)
# ----------------------------------------------------------------------------
# No extra env vars needed: embedded session auth activates automatically
# when SHOPIFY_CLIENT_ID + SHOPIFY_CLIENT_SECRET are set and the app is
# loaded inside the Shopify admin (?embedded=1&host=...). ADMIN_TOKEN keeps
# protecting standalone (Render) access.
